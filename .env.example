# BuildKit для кэширования sherpa-onnx (не пересобирать при изменении кода)
DOCKER_BUILDKIT=1

# Пути к моделям на хосте (монтируются в Docker)
# Whisper: папка с ggml-large-v3-turbo.bin
WHISPER_MODELS_HOST=./models/whisper
# GigaAM: папка с model.int8.onnx и tokens.txt
GIGAAM_MODELS_HOST=./models/gigaam-v3-ctc-ru
# Parakeet TDT 0.6B (опционально): encoder.int8.onnx, decoder.int8.onnx, joiner.int8.onnx, tokens.txt
# PARAKEET_MODELS_HOST=./models/parakeet-tdt-0.6b-v3-int8

# TLS и auth (опционально)
# Генерация ключа: live-transcribe-server-reliable --generate-key --key-name myclient
# Добавить хэш в settings.json api_keys: [{"name":"myclient","hash":"sha256:..."}]
# LOCALVOX_API_KEY=your-api-key
# TLS_CERT_PATH=./certs/server.pem
# TLS_KEY_PATH=./certs/server.key
